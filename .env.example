APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_SEO_DESCRIPTION="HomeSpace - Cua hang noi that voi cac san pham chat luong cho khong gian song hien dai."
APP_FAVICON_PATH=images/logoHomeSpace.png

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=BTL_CD1
DB_USERNAME=laravel
DB_PASSWORD=laravel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CHATBOT_PROVIDER=openrouter
CHATBOT_FORCE_VIETNAMESE=true
CHATBOT_SYSTEM_PROMPT="Bạn là trợ lý AI cho cửa hàng nội thất. Hãy trả lời ngắn gọn, rõ ràng và thân thiện."

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_SYSTEM_PROMPT="Bạn là trợ lý AI cho cửa hàng nội thất. Hãy trả lời ngắn gọn, rõ ràng và thân thiện."

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_FALLBACK_MODELS=openrouter/auto
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME="Laravel CD1 Chatbot"

VITE_APP_NAME="${APP_NAME}"

# Docker Compose variables (used by docker-compose.yml)
MYSQL_DATABASE=BTL_CD1
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=laravel
MYSQL_PASSWORD=laravel
PMA_HOST=db
PMA_PORT=3306
PMA_USER=root
PMA_PASSWORD=root
